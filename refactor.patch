-  if (!dbInstance) {
-    throw new Error('Database not initialized. Call DatabaseManager.getInstance().initialize() first.');
-  }
-  return dbInstance;
-}
-
-/**
- * Initialize and get database manager
- */
-export async function initializeDatabase(): Promise<Database> {
